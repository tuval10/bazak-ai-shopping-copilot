{
  "name": "@bazak/server",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "mastra build",
    "start": "mastra build && node .mastra/output/index.mjs",
    "dev": "mastra dev",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "eval": "EVAL_EXPOSE_TRACE=1 vitest run --config vitest.eval.config.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/openai": "^4.0.2",
    "@bazak/shared": "*",
    "@mastra/ai-sdk": "^1.6.0",
    "@mastra/core": "^1.47.0",
    "@mastra/libsql": "^1.14.2",
    "@mastra/loggers": "^1.2.0",
    "@mastra/memory": "^1.21.2",
    "@mastra/observability": "^1.15.2",
    "ai": "^7.0.4",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@mastra/evals": "^1.5.0",
    "@types/node": "^22.0.0",
    "mastra": "^1.16.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.9"
  }
}
